{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(glab *)",
      "Bash(acli *)",
      "Bash(git *)",
      "Bash(jq *)",
      "Bash(bash *)",
      "Bash(cat *)",
      "Bash(chmod *)",
      "Bash(find *)",
      "Bash(mise *)",
      "Bash(pod *)",
      "Bash(ls *)",
      "Bash(rm *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(wait)",
      "WebSearch",
      "WebFetch"
    ],
    "ask": [
      "Bash(brew *)",
      "Bash(npm *)",
      "Bash(curl *)",
      "Bash(python3 *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(git push --force *)",
      "Bash(glab mr merge *)",
      "Bash(glab mr close *)",
      "Bash(acli jira workitem delete *)"
    ],
    "defaultMode": "auto"
  }
}

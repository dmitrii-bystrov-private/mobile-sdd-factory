{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(glab *)",
      "Bash(acli *)",
      "Bash(git *)",
      "Bash(jq *)",
      "Bash(bash *)",
      "Bash(chmod *)",
      "Bash(find *)",
      "Bash(brew *)",
      "Bash(npm *)",
      "Bash(curl *)",
      "Bash(python3 *)",
      "Bash(mkdir *)",
      "Bash(rm *)",
      "WebSearch",
      "mcp__ios-rag__search",
      "mcp__ios-rag__semantic_search",
      "mcp__ios-rag__read_file",
      "mcp__ios-rag__graph_neighbors",
      "mcp__android-rag__search",
      "mcp__android-rag__semantic_search",
      "mcp__android-rag__read_file",
      "mcp__android-rag__graph_neighbors"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(git push --force *)",
      "Bash(glab mr merge *)",
      "Bash(glab mr close *)",
      "Bash(acli jira workitem delete *)"
    ]
  },
  "sandbox": {
    "enabled": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-spec.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}

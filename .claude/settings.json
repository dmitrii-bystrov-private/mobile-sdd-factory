{
  "permissions": {
    "allow": [
      "Bash(gws:*)",
      "Bash(glab:*)",
      "Bash(acli:*)",
      "Bash(jq:*)",
      "Bash(grep:*)",
      "Bash(echo:*)",
      "Bash(date:*)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(glab mr merge:*)",
      "Bash(glab mr close:*)",
      "Bash(acli jira workitem delete:*)"
    ],
    "sandbox": {
      "enabled": true,
      "autoAllowBashIfSandboxed": true
    }
  }
}

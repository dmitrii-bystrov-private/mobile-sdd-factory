# =============================================================================
# Secrets & credentials
# =============================================================================
.env
.env.*
!.env.example
*.token
*.secret
secrets/
credentials/

# =============================================================================
# Obsidian vault
# =============================================================================
# Workspace state (per-device, no need to share)
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Cache & plugins (rebuilt locally)
.obsidian/cache
.obsidian/plugins/
!.obsidian/plugins/.gitkeep

# Optional: keep core vault config but ignore plugins
# If you want to share your vault config (themes, hotkeys), comment out below:
# .obsidian/

# Obsidian trash
.trash/

# =============================================================================
# macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# =============================================================================
# Node / npm (for CLI tools & scripts)
# =============================================================================
node_modules/
npm-debug.log*
yarn-error.log*
.npm/
.yarn/

# =============================================================================
# Python (if any automation scripts)
# =============================================================================
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# =============================================================================
# Logs & temporary files
# =============================================================================
*.log
logs/
tmp/
temp/
.cache/

# =============================================================================
# Claude local settings (device-specific, not shared)
# =============================================================================
.claude/settings.local.json

# =============================================================================
# Editor & IDE
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# OS
# =============================================================================
Thumbs.db
ehthumbs.db
Desktop.ini
